<%- include('header', { title: 'Search Events', leaflet: true }) %>

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
    <h1 class="mb-0">Find Volunteer Events</h1>
    <a href="/events/new" class="btn btn-primary">Create Event</a>
</div>

<!-- Search Form -->
<form action="/search" method="GET" class="row g-3 mb-4">
    <div class="col-md-4">
        <input type="text" name="search" class="form-control" placeholder="Search events..."
               value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
    </div>
    <div class="col-md-3">
        <select name="date_filter" class="form-select">
            <option value="">All Dates</option>
            <option value="upcoming" <%= dateFilter === 'upcoming' ? 'selected' : '' %>>Upcoming</option>
            <option value="past" <%= dateFilter === 'past' ? 'selected' : '' %>>Past</option>
            <option value="this_week" <%= dateFilter === 'this_week' ? 'selected' : '' %>>This Week</option>
            <option value="this_month" <%= dateFilter === 'this_month' ? 'selected' : '' %>>This Month</option>
        </select>
    </div>
    <div class="col-md-3">
        <input type="number" name="max_distance" class="form-control" step="1" min="1" placeholder="Max distance (miles)"
               value="<%= typeof maxDistance !== 'undefined' ? maxDistance : '' %>">
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
    </div>
    <div class="col-12">
        <label class="form-label">Search from a location</label>
        <div id="search-map" class="mb-2"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <input type="text" id="location_lat" name="location_lat" class="form-control" placeholder="Latitude"
                       value="<%= typeof locationLat !== 'undefined' ? locationLat : '' %>">
            </div>
            <div class="col-md-6">
                <input type="text" id="location_lng" name="location_lng" class="form-control" placeholder="Longitude"
                       value="<%= typeof locationLng !== 'undefined' ? locationLng : '' %>">
            </div>
        </div>
        <div class="form-text">Click the map to set search location; the page will use those coordinates to filter nearby events.</div>
    </div>
</form>

<!-- Results -->
<% if (events && events.length > 0) { %>
    <div class="row">
        <% events.forEach(function(event) { %>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title"><%= event.title %></h5>
                        <p class="card-text text-muted small">
                            Organized by: <strong><%= event.organizer_name || 'Unknown' %></strong>
                        </p>
                        <% if (typeof event.distance_miles !== 'undefined' && event.distance_miles !== null) { %>
                            <p class="card-text text-muted small">
                                📍 <%= event.distance_miles.toFixed(1) %> miles away
                            </p>
                        <% } %>
                        <p class="card-text">
                            <%= event.description.substring(0, 120) %><%= event.description.length > 120 ? '...' : '' %>
                        </p>
                        <p class="card-text">
                            <small class="text-muted">
                                📅 <%= new Date(event.date).toLocaleDateString('en-US', {
                                    weekday: 'short', year: 'numeric', month: 'short', day: 'numeric'
                                }) %>
                                at <%= new Date(event.date).toLocaleTimeString('en-US', {
                                    hour: '2-digit', minute: '2-digit'
                                }) %>
                            </small>
                        </p>
                        <p class="card-text">
                            <small class="text-muted">
                                👥 <%= event.volunteer_count %> volunteer(s)
                            </small>
                        </p>
                        <a href="/events/<%= event.event_id %>" class="btn btn-outline-success btn-sm">View Details</a>
                    </div>
                    <div class="card-footer text-muted small">
                        Posted: <%= new Date(event.post_date).toLocaleDateString() %>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
<% } else { %>
    <div class="alert alert-info">
        No events found. Try adjusting your search filters.
    </div>
<% } %>

<%- include('footer') %>
