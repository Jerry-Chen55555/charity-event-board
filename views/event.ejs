<%- include('header', { title: event.title }) %>

<div class="card shadow-sm">
    <div class="card-body">
        <h1 class="card-title"><%= event.title %></h1>
        
        <!-- Organizer Info -->
        <p class="text-muted mb-4">
            Organized by <strong><%= event.organizer_name || 'Unknown' %></strong>
            <% if (event.organizer_bio) { %>
                <br><small><%= event.organizer_bio %></small>
            <% } %>
        </p>
        
        <!-- Date & Time -->
        <div class="row mb-4">
            <div class="col-md-6">
                <h5><strong>Date & Time</strong></h5>
                <p>
                    <%= new Date(event.date).toLocaleDateString('en-US', {
                        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
                    }) %><br>
                    <%= new Date(event.date).toLocaleTimeString('en-US', {
                        hour: '2-digit', minute: '2-digit'
                    }) %>
                </p>
            </div>
            <div class="col-md-6">
                <h5><strong>Location</strong></h5>
                <% if (event.location_text) { %>
                    <p>
                        <%= event.location_text %><br>
                        <a href="https://www.google.com/maps?q=<%= event.location_text.replace('POINT(', '').replace(')', '').split(' ').reverse().join(',') %>" 
                           target="_blank" class="btn btn-outline-primary btn-sm mt-1">
                            View on Map
                        </a>
                    </p>
                <% } else { %>
                    <p>Location not specified</p>
                <% } %>
            </div>
        </div>
        
        <!-- Description -->
        <h5><strong>Description</strong></h5>
        <p><%= event.description %></p>
        
        <!-- Schedule -->
        <% if (event.schedule) { %>
            <h5 class="mt-4">🕒 Schedule</h5>
            <pre class="bg-light p-3 rounded"><%= event.schedule %></pre>
        <% } %>
        
        <!-- Volunteers -->
        <h5 class="mt-4">👥 Volunteers (<%= volunteers.length %>)</h5>
        <% if (volunteers.length > 0) { %>
            <ul class="list-group list-group-flush">
                <% volunteers.forEach(function(vol) { %>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <%= vol.first_name %> <%= vol.last_name %>
                        <span class="text-muted">@<%= vol.username %></span>
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <p class="text-muted">No volunteers signed up yet. Be the first!</p>
        <% } %>
        
        <!-- Sign Up Button -->
        <div class="mt-4">
            <button class="btn btn-primary btn-lg">Sign Up to Volunteer</button>
        </div>
    </div>
    <div class="card-footer text-muted">
        Posted on <%= new Date(event.post_date).toLocaleDateString() %>
    </div>
</div>

<%- include('footer') %>