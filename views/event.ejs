<%- include('header', { title: event.title, leaflet: true }) %>

<div class="card shadow-sm">
    <div class="card-body">
        <h1 class="card-title"><%= event.title %></h1>
        <% if (typeof message !== 'undefined' && message) { %>
            <div class="alert alert-<%= message.type %>"><%= message.text %></div>
        <% } %>
        
        <!-- Organizer Info -->
        <p class="text-muted mb-4">
            Organized by
            <strong>
                <%= [event.organizer_first, event.organizer_last].filter(Boolean).join(' ') || event.organizer_name || 'Unknown' %>
            </strong>
            <% if (event.organizer_bio) { %>
                <br><small><%= event.organizer_bio %></small>
            <% } %>
        </p>
        
        <!-- Date & Time -->
        <div class="row mb-4">
            <div class="col-md-6">
                <h5><strong>Date & Time</strong></h5>
                <p>
                    <%= new Date(event.date).toLocaleDateString('en-US', {
                        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
                    }) %><br>
                    <%= new Date(event.date).toLocaleTimeString('en-US', {
                        hour: '2-digit', minute: '2-digit'
                    }) %>
                </p>
            </div>
            <div class="col-md-6">
                <div class="col-md-6">
                    <h5><strong>Location</strong></h5>
                    <% if (event.latitude && event.longitude) { %>
                        <div id="event-location-map" 
                            data-lat="<%= event.latitude %>" 
                            data-lng="<%= event.longitude %>"
                            style="height: 360px; background: #e9ecef;"></div>
                    <% } else { %>
                        <p>Location not specified</p>
                    <% } %>
                </div>
            </div>
        </div>
        
        <!-- Description -->
        <h5><strong>Description</strong></h5>
        <p><%= event.description %></p>
        
        <!-- Schedule -->
        <% if (event.schedule) { %>
            <h5 class="mt-4">🕒 Schedule</h5>
            <pre class="bg-light p-3 rounded"><%= event.schedule %></pre>
        <% } %>
        
        <!-- Volunteers -->
        <h5 class="mt-4">👥 Volunteers (<%= volunteers.length %>)</h5>
        <% if (volunteers.length > 0) { %>
            <ul class="list-group list-group-flush">
                <% volunteers.forEach(function(vol) { %>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <%= [vol.first_name, vol.last_name].filter(Boolean).join(' ') || vol.username %>
                        <span class="text-muted">@<%= vol.username %></span>
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <p class="text-muted">No volunteers signed up yet. Be the first!</p>
        <% } %>
        
        <% /* Location map already shown in the location column above */ %>
        <!-- Sign Up Button -->
        <div class="mt-4">
            <% if (typeof isAuthenticated !== 'undefined' && !isAuthenticated) { %>
                <a href="/login?returnTo=/events/<%= event.event_id %>" class="btn btn-primary btn-lg">Log In to Volunteer</a>
            <% } else if (typeof isOrganizer !== 'undefined' && isOrganizer) { %>
                <a href="/history" class="btn btn-outline-primary btn-lg">View Organizer History</a>
            <% } else if (typeof isSignedUp !== 'undefined' && isSignedUp) { %>
                <a href="/history" class="btn btn-outline-primary btn-lg">View My History</a>
            <% } else { %>
                <form action="/events/<%= event.event_id %>/signup" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-primary btn-lg">Sign Up to Volunteer</button>
                </form>
            <% } %>
        </div>
    </div>
    <div class="card-footer text-muted">
        Posted on <%= new Date(event.post_date).toLocaleDateString() %>
    </div>
</div>

<%- include('footer') %>